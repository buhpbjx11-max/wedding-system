NODE_ENV=development
PORT=3000

# Enable local demo auth mode for local startup.
LOCAL_AUTH_BYPASS=true

# Session secret for cookie/JWT signing.
JWT_SECRET=local-dev-secret-change-me

# Optional DB connection. If omitted, the app uses in-memory fallback data.
# DATABASE_URL=mysql://user:password@localhost:3306/wedding_os

# Optional OAuth integration. If omitted, local demo mode stays active.
# VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example
# OAUTH_SERVER_URL=https://your-oauth-server.example
# VITE_APP_ID=your-app-id
# OWNER_OPEN_ID=owner-open-id
